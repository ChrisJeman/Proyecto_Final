{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar todo el proyecto",
      "type": "shell",
      "command": "C:\\Program Files\\MSYS2\\ucrt64\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "src/*.cpp",
        "-o",
        "main.exe",
        "-Iinclude"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
